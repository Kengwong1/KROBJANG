# ════════════════════════════════════════════════════════
#  ครบจังดอทคอม — .env.example
#  คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
#  อย่า commit .env ขึ้น GitHub เด็ดขาด!
# ════════════════════════════════════════════════════════

# ── Path & Site ──────────────────────────────────────────
BASE_PATH=D:/Projects/krubjang-site%20full   # path โฟลเดอร์เว็บ (ถ้าไม่กำหนด ใช้โฟลเดอร์ script)
SITE_URL=https://krobjang.vercel.app
SITE_NAME=ครบจังดอทคอม
SITE_DESC=เว็บเดียวครบทุกเรื่อง ใช้งานง่ายทุกวัย

# ── Ollama (AI local) ────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=scb10x/llama3.1-typhoon2-8b-instruct:latest
RETRY_COUNT=3
RETRY_WAIT=5

# ── รูปภาพ ───────────────────────────────────────────────
UNSPLASH_KEY=               # https://unsplash.com/developers → New Application

# ── โฆษณา ────────────────────────────────────────────────
ADSENSE_PUB=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_SLOT=XXXXXXXXXX
GA4_ID=G-XXXXXXXXXX         # Google Analytics 4 (ถ้ามี)

# ── Social ───────────────────────────────────────────────
FB_PAGE_ID=                 # Facebook Page ID
FB_PAGE_TOKEN=              # Facebook Page Access Token
LINE_NOTIFY_TOKEN=          # Line Notify token

# ── Push Notification ────────────────────────────────────
ONESIGNAL_APP_ID=           # OneSignal (ถ้าใช้)

# ── Affiliate ────────────────────────────────────────────
LAZADA_AFFILIATE=           # Lazada Affiliate ID
SHOPEE_AFFILIATE=           # Shopee Affiliate ID
AGODA_AFFILIATE=            # Agoda CID
