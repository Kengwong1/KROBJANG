# ════════════════════════════════════════════════════════════════
#  .gitignore — ครบจังดอทคอม / ไอหมอก
#  ไฟล์ที่ไม่ควรขึ้น GitHub/Vercel
# ════════════════════════════════════════════════════════════════

# ── 🤖 Agent & Script ทุกตัว ────────────────────────────────────
agent_*.py
fix_*.py
patch_*.py
inject_*.py
config.py

# ── 🔑 Secret / API Key ─────────────────────────────────────────
.env
*.env
.env.*
secrets.py
api_keys.py

# ── 🐍 Python cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/

# ── 📦 Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json

# ── 🖥️  OS ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── 🗂️  Venv / Virtual Env ──────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── 📋 Log / Temp ────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*.swo
agent_logs/
logs/

# ── 🛠️  IDE & Editor ────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.cursor/

# ── 📦 Build output (ถ้าใช้ build tool) ─────────────────────────
dist/
build/
.next/
out/

# ── ☁️  Vercel ────────────────────────────────────────────────────
.vercel/

# ── 🧪 Test / Dev only ──────────────────────────────────────────
test_*.py
*_test.py
draft_*.html
test_*.html
_draft/
_test/

# ── 📊 Data / Index ที่ generate อัตโนมัติ ──────────────────────
# (ถ้าอยากให้ Vercel ใช้ version ที่ generate จาก agent ให้ comment บรรทัดนี้)
# search-index.json
# thumbnails.json

# ── 🖼️  Thumbnail SVG ที่ generate อัตโนมัติ ─────────────────────
# images/thumbs/

# ── ⚙️  Config และ Script พิเศษ ──────────────────────────────────
sw.js
# manifest.json  ← เปิดใช้ถ้ามี PWA จริง

# ── 🗑️  ไฟล์แก้ปัญหาชั่วคราว ─────────────────────────────────────
fix_now.py
fix_dup_img.py
fix_vercel_links.py
patch_home_link.py
patch_fix_search_dedup.py
patch_dedup_images.py
inject_dedup_func.py
fix_dup_search_script.py
